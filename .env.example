# ============================================================
# Helena — Configuración del Bot de Trading XRPL
# ============================================================
# Copia este archivo como .env y edita los valores.
# NUNCA subas tu .env real al repositorio.
# ============================================================

# === Conexión XRPL ===
# Testnet: wss://s.altnet.rippletest.net:51233
# Devnet:  wss://s.devnet.rippletest.net:51233
# Mainnet: wss://xrplcluster.com
XRPL_WS_URL=wss://s.altnet.rippletest.net:51233

# === Wallet ===
# Seed de tu wallet XRPL (¡NUNCA compartas esto!)
XRPL_WALLET_SEED=

# === Emisor USD ===
# Testnet: usar la dirección generada por `npm run fund:usd`
# Mainnet: Bitstamp = rvYAfWj5gh67oV6fW32ZzP3Aw4Eubs59B
USD_ISSUER=rvYAfWj5gh67oV6fW32ZzP3Aw4Eubs59B

# === Selección de Estrategia ===
# Opciones: market_maker | dorothy | elphaba | louise | anti_louise
#           masha | thusnelda | agartha | arbitrage
STRATEGY=market_maker

# === Market Maker — Spread y Orden ===
MM_BASE_SPREAD=0.01
MM_MIN_SPREAD=0.005
MM_MAX_SPREAD=0.02
MM_TIGHT_SPREAD=0.003
MM_ORDER_AMOUNT_XRP=10
MM_PRICE_DEVIATION_THRESHOLD=0.003

# === Market Maker — Cooldown y Posición ===
MM_COOLDOWN_LEDGERS=3
MM_MAX_POSITION_XRP=80
MM_TARGET_POSITION_XRP=50
MM_MIN_PROFIT_MARGIN=1.5

# === Market Maker — Carousel (ventanas en ledgers) ===
MM_CAROUSEL_TIGHT_LEDGERS=10
MM_CAROUSEL_STANDARD_LEDGERS=10
MM_CAROUSEL_IOC_LEDGERS=5
MM_CAROUSEL_REST_LEDGERS=5
MM_CAROUSEL_REST_MAX_LEDGERS=20
MM_IOC_MIN_DEX_EDGE=0.002

# === DCA — Configuración común ===
MAX_RUNGS=3
RUNG_QTY_XRP=10

# === Dorothy (DCA Long) ===
DOROTHY_PROFIT_FACTOR=0.05
DOROTHY_MARGIN_DROP_FACTOR=0.03

# === Elphaba (DCA Short) ===
ELPHABA_PROFIT_FACTOR=0.05
ELPHABA_MARGIN_RISE_FACTOR=0.03

# === Louise (Long DCA + Lucky Strike) ===
LOUISE_PROFIT_TARGET_PCT=5.0
LOUISE_DCA_STEP_PCT=3.0

# === Anti-Louise (Short DCA + Lucky Strike) ===
ANTI_LOUISE_PROFIT_TARGET_PCT=5.0
ANTI_LOUISE_DCA_STEP_PCT=3.0

# === Masha (Multi-Timeframe DCA) ===
MASHA_PROFIT_FACTOR=2.0
MASHA_MA_PERIODS_1W=20
MASHA_MA_PERIODS_1H=20
MASHA_MARGIN_LOW_1W=2.0
MASHA_MARGIN_LOW_1H=1.0
MASHA_BUY_QTY_BASE=10

# === Thusnelda (Basket DCA Multi-Token) ===
THUSNELDA_SYMBOLS_CSV=XRP,ADA,DOT
THUSNELDA_FACTOR_MULT=0.97
THUSNELDA_META_EQUITY_USDT=100.0
THUSNELDA_MAX_DRAWDOWN_PCT=15.0
THUSNELDA_QUOTE_QTY=10.0

# === Agartha (Moonshot + Trailing Stop) ===
AGARTHA_TRAILING_STOP_PCT=15.0
AGARTHA_ACTIVATION_PROFIT_PCT=10.0
AGARTHA_ENTRY_LIMIT_OFFSET_PCT=2.0
AGARTHA_MAX_HOLDING_LEDGERS=1000

# === Arbitraje DEX-CEX ===
ARB_MIN_SPREAD_PCT=0.15
ARB_MAX_TRADE_XRP=50
ARB_MIN_TRADE_XRP=10
ARB_MAX_POSITION_XRP=200
ARB_COOLDOWN_LEDGERS=2
ARB_MAX_SLIPPAGE_PCT=0.10
ARB_MIN_ORACLE_CONFIDENCE=0.6
ARB_MIN_ORACLE_SOURCES=2

# === Binance CEX (para estrategia 'arbitrage') ===
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_BASE_URL=https://api.binance.com

# === Seguridad y Mitigación ===
HALT_ON_ORACLE_FAILURE=true
ORACLE_MAX_AGE_SECONDS=60
MAX_FEE_DROPS=50000
MIN_XRP_RESERVE_BUFFER=10.0

# === Oráculos (desactivar individualmente) ===
# DISABLE_CRYPTOCOMPARE=true
# DISABLE_BINANCE=true
# DISABLE_KRAKEN=true
# DISABLE_COINBASE=true

# === Dashboard Web ===
DASHBOARD_PORT=3000
DASHBOARD_TOKEN=

# === Telegram (opcional) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Logging ===
# Niveles: DEBUG | INFO | WARN | ERROR
LOG_LEVEL=INFO
