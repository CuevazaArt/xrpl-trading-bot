# Endpoint de WebSocket para XRPL (ejemplos)
# Testnet: wss://s.altnet.rippletest.net:51233
# Devnet: wss://s.devnet.rippletest.net:51233
# Mainnet (ejemplo): wss://xrplcluster.com
XRPL_WS_URL=wss://s.altnet.rippletest.net:51233

# Wallet credentials (para pruebas, usar una dirección de Testnet generada)
# ¡NUNCA pongas llaves reales en producción en este archivo directamente sin encriptación!
XRPL_WALLET_SEED=

# === Selección de Estrategia ===
# Estrategias disponibles:
# - market_maker: Creador de mercado básico con spread y sesgo de inventario
# - dorothy: DCA Long (Compra en caídas dentro de tendencias alcistas + Take Profit)
# - elphaba: DCA Short en Spot (Venta de XRP en subidas en tendencia bajista + recompra limitada barata)
STRATEGY=market_maker

# === Configuración común de DCA (Dorothy/Elphaba) ===
MAX_RUNGS=3
RUNG_QTY_XRP=10

# === Configuración de Dorothy ===
DOROTHY_PROFIT_FACTOR=0.05
DOROTHY_MARGIN_DROP_FACTOR=0.03

# === Configuración de Elphaba ===
ELPHABA_PROFIT_FACTOR=0.05
ELPHABA_MARGIN_RISE_FACTOR=0.03

# === Configuración de Louise (Long DCA + Lucky Strike HA) ===
LOUISE_PROFIT_TARGET_PCT=5.0
LOUISE_DCA_STEP_PCT=3.0

# === Configuración de Anti-Louise (Short DCA + Lucky Strike HA) ===
ANTI_LOUISE_PROFIT_TARGET_PCT=5.0
ANTI_LOUISE_DCA_STEP_PCT=3.0

# === Configuración de Masha (Multi-timeframe DCA 1w+1h) ===
MASHA_PROFIT_FACTOR=2.0
MASHA_MA_PERIODS_1W=20
MASHA_MA_PERIODS_1H=20
MASHA_MARGIN_LOW_1W=2.0
MASHA_MARGIN_LOW_1H=1.0
MASHA_BUY_QTY_BASE=10

# === Configuración de Thusnelda (Basket Spot DCA + Exit Global) ===
THUSNELDA_SYMBOLS_CSV=XRP,ADA,DOT
THUSNELDA_FACTOR_MULT=0.97
THUSNELDA_META_EQUITY_USDT=100.0
THUSNELDA_MAX_DRAWDOWN_PCT=15.0
THUSNELDA_QUOTE_QTY=10.0

# === Configuración de Agartha (Moonshot Trailing + Entry-Limit) ===
AGARTHA_TRAILING_STOP_PCT=15.0
AGARTHA_ACTIVATION_PROFIT_PCT=10.0
AGARTHA_ENTRY_LIMIT_OFFSET_PCT=2.0
AGARTHA_MAX_HOLDING_LEDGERS=1000

